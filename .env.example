# Adrik Compendium — Variables de entorno
# Copia este archivo como .env y completa los valores

# Google Docs — ID del documento con el historial de la campaña
# Lo encuentras en la URL: docs.google.com/document/d/ESTE_ES_EL_ID/edit
GOOGLE_DOC_ID=

# Google Service Account — ruta al archivo JSON de credenciales
# Descárgalo desde Google Cloud Console → IAM → Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-service-account.json
